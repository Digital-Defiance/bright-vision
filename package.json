{
  "name": "aider-vision",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "tauri build --target universal-apple-darwin --bundles dmg",
    "audit:core": "python aider-vision-core/scripts/audit_rename_compat.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test",
    "test:e2e": "playwright test",
    "test:all": "yarn tsc --noEmit && yarn test && yarn test:rust && yarn test:e2e",
    "test:git-workspace": "cd aider-vision-core && python -m pytest tests/basic/test_git_workspace.py -q",
    "verify:submodule": "sh scripts/verify_submodule.sh",
    "sync:core": "bash aider-vision-core/scripts/sync_aider_vision.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sass": "^1.83.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.1.0"
  }
}
