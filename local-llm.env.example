# Copy to local-llm.env in this directory (gitignored). BrightVision reads on launch.
# You do not need the separate local-llm git repo or local-llm.sh — use Terminal → Local LLM in the app.

OLLAMA_HOST=http://127.0.0.1:11434
DATA_MODEL=qwen3.6:27b-q4_K_M

# Settings → LLM model should be ollama_chat/<DATA_MODEL> (filled on launch / Sync from env).

# Optional — Local model router (Settings → Sync from env files applies these):
# MODEL_ROUTER=1
# FAST_MODEL=deepseek-coder:6.7b
# HEAVY_MODEL=qwen3.6:27b-q4_K_M
# If HEAVY_MODEL is omitted, the heavy tier uses DATA_MODEL / session LLM.

# INDEX_MODEL / EMBEDDING_MODEL are ignored unless you use the local-llm indexing stack elsewhere.
